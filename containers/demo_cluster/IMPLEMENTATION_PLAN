### Phase 5: Main Test Flow

**File**: `src/main.rs`

Structure like `kms-flow-simulation/main.rs` with optional KMS launching and worker support:

```rust
#![feature(let_chains)]

use anyhow::{Context, Result};
use clap::Parser;
use tracing::{info, error};

mod program_executor_client;
mod fake_data_read_write_ffi;
mod kms_client;
mod client_simulator;
mod key_derivation;
mod attestation_factory;
mod pipeline_simulator;
mod launcher_module;

use launcher_module::{Launcher, Args, TrustedApplicationAddress};

#[derive(Parser, Debug)]
pub struct DemoArgs {
    #[command(flatten)]
    pub launcher_args: Args,

    /// KMS address (if not provided, launches KMS using launcher_module)
    #[arg(long)]
    pub kms_address: Option<String>,

    /// KMS bundle path (required if kms_address not provided)
    #[arg(long)]
    pub kms_bundle: Option<PathBuf>,

    /// Number of distributed workers to launch (0 = single-node execution)
    #[arg(long, default_value = "0")]
    pub num_workers: u32,

    /// Worker bundle path (required if num_workers > 0)
    #[arg(long)]
    pub worker_bundle: Option<PathBuf>,
}

#[tokio::main]
async fn main() -> Result<()> {
    tracing_subscriber::fmt().with_max_level(tracing::Level::INFO).init();
    let args = DemoArgs::parse();

    info!("=== Program Executor Demo Cluster ===");

    // ========================================================================
    // Step 1: Start FakeDataReadWriteService
    // ========================================================================
    info!("\n--- Step 1: Start FakeDataReadWriteService ---");
    let fake_data_service = FakeDataReadWriteService::new();
    let data_service_port = fake_data_service.start_server("[::1]:0")?;
    let data_service_address = format!("[::1]:{}", data_service_port);
    info!("FakeDataReadWriteService listening at: {}", data_service_address);

    // ========================================================================
    // Step 2: Launch or Connect to KMS
    // ========================================================================
    info!("\n--- Step 2: Launch/Connect KMS ---");
    let (kms_address, kms_launcher) = if let Some(addr) = args.kms_address {
        info!("Using provided KMS address: {}", addr);
        (addr, None)
    } else {
        info!("No KMS address provided, launching KMS TEE...");
        let kms_bundle = args.kms_bundle
            .context("--kms-bundle required when --kms-address not provided")?;

        let kms_args = Args {
            system_image: args.launcher_args.system_image.clone(),
            container_bundle: kms_bundle,
            qemu_params: args.launcher_args.qemu_params.clone(),
            communication_channel: args.launcher_args.communication_channel.clone(),
            ..Default::default()
        };

        let mut launcher = Launcher::create(kms_args).await?;
        let address = launcher.get_trusted_app_address().await?;
        let addr = format!("http://{}", address);
        info!("KMS TEE launched at: {}", addr);
        (addr, Some(launcher))
    };

    // ========================================================================
    // Step 3: Launch Worker TEEs (if distributed execution requested)
    // ========================================================================
    let mut worker_launchers = Vec::new();
    let mut worker_bns_addresses = Vec::new();

    if args.num_workers > 0 {
        info!("\n--- Step 3: Launch {} Worker TEEs ---", args.num_workers);
        let worker_bundle = args.worker_bundle
            .context("--worker-bundle required when --num-workers > 0")?;

        for i in 0..args.num_workers {
            info!("Launching worker {} of {}...", i + 1, args.num_workers);

            let worker_args = Args {
                system_image: args.launcher_args.system_image.clone(),
                container_bundle: worker_bundle.clone(),
                qemu_params: args.launcher_args.qemu_params.clone(),
                communication_channel: args.launcher_args.communication_channel.clone(),
                ..Default::default()
            };

            let mut launcher = Launcher::create(worker_args).await?;
            let address = launcher.get_trusted_app_address().await?;
            let worker_addr = format!("http://{}", address);
            info!("Worker {} started at: {}", i + 1, worker_addr);

            worker_bns_addresses.push(worker_addr);
            worker_launchers.push(launcher);
        }
    } else {
        info!("\n--- Step 3: Single-node execution (no workers) ---");
    }

    // ========================================================================
    // Step 4: Store Client Test Data
    // ========================================================================
    info!("\n--- Step 4: Store Client Test Data ---");
    let client_ids = vec!["client1".to_string(), "client2".to_string()];
    let client_data_dir = "test_data";

    for client_id in &client_ids {
        let uri = format!("{}/{}", client_data_dir, client_id);
        let tensor_data = create_test_tensor_data(client_id);
        fake_data_service.store_encrypted_message_for_kms(&uri, &tensor_data, None)?;
        info!("Stored test data for {}", client_id);
    }

    // ========================================================================
    // Step 5: Launch Program Executor TEE
    // ========================================================================
    info!("\n--- Step 5: Launch Program Executor TEE ---");
    let mut launcher = Launcher::create(args.launcher_args).await?;
    let trusted_app_address = launcher.get_trusted_app_address().await?;
    let tee_address = format!("http://{}", trusted_app_address);
    info!("Program executor TEE started at: {}", tee_address);

    // Get endorsed evidence and derive reference values
    let endorsed_evidence = launcher.get_endorsed_evidence().await?;
    let reference_values = extract_reference_values(&endorsed_evidence)?;

    // Get worker reference values (if distributed)
    let worker_reference_values = if !worker_launchers.is_empty() {
        let worker_evidence = worker_launchers[0].get_endorsed_evidence().await?;
        Some(extract_reference_values(&worker_evidence)?)
    } else {
        None
    };

    // ========================================================================
    // Step 6: Connect to KMS and Prepare Keys
    // ========================================================================
    info!("\n--- Step 6: Connect to KMS ---");
    let mut kms_client = KmsClient::new(&kms_address).await?;

    kms_client.rotate_keyset(1, 7200).await?;
    let access_policy = create_program_executor_access_policy(reference_values.clone());
    let policy_hash = compute_policy_hash(&access_policy);
    let public_keys = kms_client.derive_keys(1, vec![policy_hash.clone()]).await?;

    // ========================================================================
    // Step 7: Register Pipeline and Authorize
    // ========================================================================
    info!("\n--- Step 7: Register Pipeline and Authorize ---");
    let (invocation_id, _) = kms_client.register_pipeline_invocation(...).await?;
    let (protected_response, signing_key_endorsement) = kms_client.authorize_transform(
        invocation_id, ..., launcher_evidence, launcher_endorsements
    ).await?;

    // ========================================================================
    // Step 8: Initialize Program Executor with Python Program
    // ========================================================================
    info!("\n--- Step 8: Initialize Program Executor ---");
    let program = r#"
def trusted_program(input_provider, external_service_handle):
    import federated_language

    # Sum client data
    total = 0
    for client_id in input_provider.client_ids:
        tensor = input_provider.resolve_uri_to_tensor(client_id, "data")
        total += sum(tensor.int64_val)

    # Release result
    result = str(total).encode()
    external_service_handle.release_unencrypted(result, b"result")
"#;

    let mut program_client = ProgramExecutorClient::new(&tee_address).await?;
    program_client.initialize_with_program(
        protected_response,
        program,
        client_ids,
        client_data_dir.to_string(),
        data_service_address,
        worker_bns_addresses,           // Pass worker addresses for distributed execution
        worker_reference_values,         // Pass worker reference values for Noise sessions
        vec![],                          // No model files for this example
    ).await?;

    // ========================================================================
    // Step 9: Execute Session
    // ========================================================================
    info!("\n--- Step 9: Execute Python Program ---");
    let (results, release_token) = program_client.execute_session().await?;

    // ========================================================================
    // Step 10: Verify Results
    // ========================================================================
    info!("\n--- Step 10: Verify Results ---");
    let released_data = fake_data_service.get_released_data("result");
    info!("Result from TEE: {:?}", String::from_utf8_lossy(&released_data.unwrap_or_default()));

    // ========================================================================
    // Step 11: Release with KMS
    // ========================================================================
    info!("\n--- Step 11: Release Results ---");
    kms_client.release_results(vec![(release_token, signing_key_endorsement)]).await?;

    // ========================================================================
    // Cleanup
    // ========================================================================
    info!("\n--- Cleanup ---");
    for mut worker in worker_launchers {
        let _ = worker.kill().await;
    }
    if let Some(mut kms) = kms_launcher {
        let _ = kms.kill().await;
    }

    info!("\n=== Demo Complete ===");
    Ok(())
}
```

